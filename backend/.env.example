# ==========================================
# SubTrack — Environment Variables
# ==========================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง

# Database (Supabase หรือ Railway PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# JWT Secret (ใส่ random string ยาวๆ)
JWT_SECRET=your-super-secret-jwt-key-change-this

# SendGrid (สมัครที่ sendgrid.com)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=SubTrack

# Omise Payment (สมัครที่ opn.ooo หรือ omise.co)
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxx

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
